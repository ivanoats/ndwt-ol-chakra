{
  "name": "northwest_discovery_water_trail_map",
  "version": "1.0.1",
  "author": {
    "name": "Ivan Storck",
    "email": "ivan@ivanstorck.com",
    "url": "https://github.com/ivanoats"
  },
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "commit": "cz",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "serve out --listen 4173 --no-clipboard --single",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint src e2e app playwright.config.ts --ext .tsx --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "format": "prettier --config ./.prettierrc -w '{src,e2e,app}/**/*.{tsx,ts}' playwright.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky install"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.3",
    "@chakra-ui/react": "^2.10.9",
    "@chakra-ui/system": "^2.6.2",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@testing-library/dom": "^10.4.1",
    "framer-motion": "^12.38.0",
    "next": "^16.2.4",
    "ol": "^10.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.14.0",
    "prettier": "^3.3.3",
    "rollup": "^4.24.0",
    "serve": "^14.2.6",
    "typescript": "^5.6.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
